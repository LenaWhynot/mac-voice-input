+def _install_macos_tap_keepalive(on_reenable=None) -> None:
+    """macOS: переживать отключение глобального event-tap.
+
+    Корень «залипания» виспи: macOS гасит CGEventTap (timeout, если колбэк
+    подвис; или по флуду user-input; или после сна) и шлёт событие-маркер
+    kCGEventTapDisabledByTimeout / ...ByUserInput. Эта версия pynput его НЕ
+    переподнимает — listener жив, рунлуп крутится, но клавиши больше не доходят
+    → правый Option «мёртв» до перезапуска процесса.
+
+    Патчим darwin-backend: запоминаем хэндл тапа и в колбэке ловим disable-маркер
+    → CGEventTapEnable(tap, True). Тап оживает сам, без рестарта. Идемпотентно.
+
+    on_reenable: опциональный колбэк без аргументов, вызывается после успешного
+    переподнятия тапа (используется для авто-стопа зависших длинных записей).
+    """
+    if platform.system() != "Darwin":
+        return
+    try:
+        from pynput.keyboard import Listener as _KbL
+        from Quartz import CGEventTapEnable
+    except Exception as e:
+        logging.debug(f"tap-keepalive: backend недоступен ({e})")
+        return
+    if getattr(_KbL, "_tap_keepalive_patched", False):
+        return
+    # event_type у disable-маркеров: pyobjc отдаёт беззнаковые 0xFFFFFFFE/FF;
+    # на части версий приходят знаковые -2/-1 — покрываем оба варианта.
+    _DISABLED = {0xFFFFFFFE, 0xFFFFFFFF, -2, -1}
+    _orig_create = _KbL._create_event_tap
+    _orig_handler = _KbL._handler
+
+    def _create_event_tap(self):
+        tap = _orig_create(self)
+        self._ka_tap = tap          # сохраняем хэндл для повторного включения
+        return tap
+
+    def _handler(self, proxy, event_type, event, refcon):
+        if event_type in _DISABLED:
+            tap = getattr(self, "_ka_tap", None)
+            if tap is not None:
+                try:
+                    CGEventTapEnable(tap, True)
+                    logging.warning(
+                        "event-tap отключён macOS — переподнят (правый Option жив)")
+                    if on_reenable is not None:
+                        threading.Thread(target=on_reenable, daemon=True).start()
+                except Exception as e:
+                    logging.error(f"не удалось переподнять event-tap: {e}")
+            return event
+        return _orig_handler(self, proxy, event_type, event, refcon)
+
+    _KbL._create_event_tap = _create_event_tap
+    _KbL._handler = _handler
+    _KbL._tap_keepalive_patched = True
+    logging.info("tap-keepalive установлен: пережёвываем отключения event-tap")
+
